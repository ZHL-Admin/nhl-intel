# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Ignore environment files
.env
.env.*
!.env.example

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# This is critical: ignore everything in parent directory except backend
../*
!../backend/**
