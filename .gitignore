# Frontend
node_modules/
frontend/dist/
frontend/.vite/

# Frontend build config must be tracked so the site builds from a clean clone,
# despite the global `*.json` GCP-key ignore above. Path-specific negations ONLY
# — the global *.json default stays in force for every other JSON in the repo.
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json
!frontend/tsconfig.node.json

# Model layer: versioned artifacts are large/binary; keep the dir, not the contents
models_ml/artifacts/*
!models_ml/artifacts/.gitkeep

# ppt-replay sprite on-disk cache (immutable, re-fetchable)
scripts/ppt_cache/

# DuckDB serving layer: rebuildable read-only snapshot of BigQuery (make export-serving)
data/serving/

# Local server logs + agent scratch output (not source)
*.log
frontend/.dx/

# Research projects (NIR/research/{project}): never commit their data or venvs.
# Each project is removable by deleting its folder with zero impact on the site.
research/*/data/
research/*/.venv/
research/*/.pytest_cache/
research/**/*.duckdb
research/**/*.parquet
research/reports/figures/*.png
