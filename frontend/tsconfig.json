{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  // RINK THEORY rebuild: src/pages is the legacy dashboard surface — removed from
  // the build (unreachable, tree-shaken by Vite). Exclude it from tsc so the
  // removed pages don't gate the new build. The four KEPT tool sources still live
  // here as dormant salvage; they re-enter the typed build when ported into
  // src/rink in Step 5.
  "exclude": ["src/pages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
